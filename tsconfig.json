{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "@cloudflare/workers-types"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@seesby/types": [
        "./packages/types/src"
      ],
      "@seesby/types/*": [
        "./packages/types/src/*"
      ],
      "@seesby/metrics": [
        "./packages/metrics/src"
      ],
      "@seesby/metrics/*": [
        "./packages/metrics/src/*"
      ],
      "@seesby/modes": [
        "./packages/modes/src"
      ],
      "@seesby/modes/*": [
        "./packages/modes/src/*"
      ],
      "@seesby/actions": [
        "./packages/actions/src"
      ],
      "@seesby/actions/*": [
        "./packages/actions/src/*"
      ],
      "@seesby/fingerprint": [
        "./packages/fingerprint/src"
      ],
      "@seesby/fingerprint/*": [
        "./packages/fingerprint/src/*"
      ],
      "@seesby/compute": [
        "./packages/compute/src"
      ],
      "@seesby/compute/*": [
        "./packages/compute/src/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
